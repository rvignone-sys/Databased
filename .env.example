# Copy to .env (in the repo root) and fill in real values.
# .env is gitignored — these are runtime secrets, never commit them.

# ─── Required ───────────────────────────────────────────────────────────────
# Flask cookie signing — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Encryption key for stored RDP/VNC passwords. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep stable across deploys — rotating invalidates every saved credential.
FERNET_KEY=

# First-boot admin user. init_db seeds (or updates the password of) this
# user every run. Pick something strong.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ─── Optional ───────────────────────────────────────────────────────────────
# Override the default SQLite location (default: pi/data/databased.db).
# DATABASE_URL=sqlite:////absolute/path/to/databased.db

# Seconds without a heartbeat before an agent is considered offline.
# HEARTBEAT_TIMEOUT=120

# ─── Guacamole (in-browser RDP/VNC) ─────────────────────────────────────────
# Where the Guacamole web UI is reachable from the dashboard.
# GUAC_BASE_URL=http://127.0.0.1:8081
# GUAC_HOST_PORT=8081
# GUAC_DATA_SOURCE=postgresql
# GUAC_ADMIN_PASS=

# ─── Pi Host remote-desktop button ──────────────────────────────────────────
# PI_HOST_PROTOCOL=vnc            # or 'rdp' (xrdp)
# PI_HOST_PORT=5901               # x11vnc default; xrdp uses 3389
# PI_HOST_FOR_GUACD=172.18.0.1   # IP guacd uses to reach the Pi host
# PI_HOST_PASSWORD=               # auto-auth so user isn't prompted
