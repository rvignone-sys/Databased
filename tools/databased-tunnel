#!/usr/bin/env bash
# Helper script invoked by the DataBased Pi service to manage the tinyproxy
# internet tunnel for offline lab PCs. Sudoers gives the service NOPASSWD
# access to just this script — the Flask process never touches /etc/ or
# systemctl directly.
#
# Usage:
#   databased-tunnel apply <ip1> [ip2] ...   # rewrite ACL with these IPs, ensure service running
#   databased-tunnel stop                    # stop tinyproxy service
#   databased-tunnel status                  # print is-active / allowed IPs

set -euo pipefail

CONF=/etc/tinyproxy/tinyproxy.conf
PORT="${TUNNEL_PORT:-8888}"

action="${1:-status}"

case "$action" in
  apply)
    shift
    if [[ $# -lt 1 ]]; then
      echo "ERROR: apply needs at least one IP" >&2
      exit 2
    fi

    # Rebuild the conf with one Allow line per IP. Any caller-controlled
    # input is filtered to digits/dots only to keep injection out of /etc.
    ALLOW_BLOCK=""
    for ip in "$@"; do
      sanitized="$(echo "$ip" | tr -cd '0-9./')"
      if [[ -n "$sanitized" ]]; then
        ALLOW_BLOCK+="Allow ${sanitized}"$'\n'
      fi
    done

    cat > "$CONF" <<EOF
# Auto-generated by databased-tunnel — do not edit by hand; changes will be
# overwritten on the next sync. Edit the IP list via the dashboard instead.
User tinyproxy
Group tinyproxy
Port $PORT
Listen 0.0.0.0
Timeout 600
DefaultErrorFile "/usr/share/tinyproxy/default.html"
StatFile "/usr/share/tinyproxy/stats.html"
LogLevel Info
PidFile "/run/tinyproxy/tinyproxy.pid"
MaxClients 50
DisableViaHeader Yes
Allow 127.0.0.1
${ALLOW_BLOCK}
EOF

    # Reload (cheaper than restart) — tinyproxy re-reads conf without dropping clients
    if systemctl is-active --quiet tinyproxy; then
      systemctl reload tinyproxy 2>/dev/null || systemctl restart tinyproxy
    else
      systemctl enable tinyproxy >/dev/null 2>&1 || true
      systemctl start tinyproxy
    fi
    echo "applied: $# IP(s) allowed; service active"
    ;;
  stop)
    systemctl stop tinyproxy
    echo "stopped"
    ;;
  status)
    if systemctl is-active --quiet tinyproxy; then
      echo "running"
    else
      echo "stopped"
    fi
    grep -E '^Allow' "$CONF" 2>/dev/null | grep -v 127.0.0.1 | awk '{print "  " $0}'
    ;;
  *)
    echo "Usage: $0 {apply <ips...> | stop | status}" >&2
    exit 2
    ;;
esac
